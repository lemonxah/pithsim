# --- pith-pedals defaults (ESP32-S3, Rust build) ---

# Console on UART0: the native USB-OTG peripheral is owned by our TinyUSB
# composite device and shares the D+/D- pins with USB-Serial-JTAG, so
# console can't use USB. Attach a 3.3V USB-UART adapter to UART0 to see logs.
CONFIG_ESP_CONSOLE_UART_DEFAULT=y

# 4 MB flash with a custom partition table: nvs + dual OTA app slots. The
# dashboard updates the device in place over HID (@OTA); espflash in ROM
# download mode (hold BOOT, tap RESET) is the first-flash/recovery path.
# Flash size is provisional pending the actual pedal board being finalized —
# adjust if the chosen board ships more.
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# Compile the ESP-IDF C side (FreeRTOS, drivers, TinyUSB) for speed — the USB
# device task and (once Phase 2 lands) the loadcell/motor driver live there.
CONFIG_COMPILER_OPTIMIZATION_PERF=y

# A failed boot after an OTA rolls back to the previous slot; the running
# image confirms itself via esp_ota_mark_app_valid_cancel_rollback().
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y
