# pithddu-firmware tasks (Rust / esp-idf). Run `just` to list.
# Source the esp env first:  source ~/export-esp.sh
set shell := ["bash", "-uc"]

default:
    @just --list

# Build the firmware (debug).
build:
    cargo build

# Build optimized.
release-build:
    cargo build --release

# Write the main firmware app into the ota_0 slot (offset 0x1a0000). The RECOVERY
# app (pith-recovery, in the factory slot) owns the bootloader + partition table —
# flash that FIRST (cd ../pith-recovery && just flash). A full flash here would
# target the factory slot and clobber recovery, so we write only the app image to
# ota_0. After this, recovery chain-loads ota_0 (NVS "mainslot" defaults to 0).
# Download mode: recovery menu "USB flash mode", or hold BOOT + tap RESET.
# --after watchdog-reset: the one reset that CLEARS the RTC force-download latch —
# after a menu-triggered (software) download mode, anything softer boots straight
# back into ROM download mode instead of the new firmware. Console is UART0.
flash port="":
    cargo build --release
    espflash save-image --chip esp32s3 \
        target/xtensa-esp32s3-espidf/release/pithddu pithddu-xiao_s3.bin
    espflash write-bin --after watchdog-reset {{ if port != "" { "-p " + port } else { "" } }} 0x1a0000 pithddu-xiao_s3.bin

# Serial monitor only.
monitor port="":
    espflash monitor {{ if port != "" { "-p " + port } else { "" } }}

# Host unit tests for the pure-logic core.
test:
    cargo +stable test -p pith-core --target x86_64-unknown-linux-gnu

# Save the bare app image (what the dashboard installs by board name).
image:
    cargo build --release
    espflash save-image --chip esp32s3 \
        target/xtensa-esp32s3-espidf/release/pithddu pithddu-xiao_s3.bin

# OTA-flash the bare app image to a RUNNING device over USB — no BOOT button, the
# same self-reflash path as the dashboard's "FLASH LOCAL BUILD" button (pith-flash
# CLI, in the host workspace). Build the bin first with `just image`. Pass a serial
# port to force it; otherwise it auto-detects (USB HID, else the first serial port).
#   just ota                  -> OTA-flash ./pithddu-xiao_s3.bin
#   just ota /dev/ttyACM0     -> force a serial port
ota port="":
    test -f pithddu-xiao_s3.bin || { echo "pithddu-xiao_s3.bin not found — run 'just image' first" >&2; exit 1; }
    cd .. && cargo run -p pith-flash --release -- {{ if port != "" { "-p " + port } else { "" } }} firmware/pithddu-xiao_s3.bin

# Cut a release by tagging + pushing (CI builds the bins and publishes the GitHub Release).
#   just release           -> bump the patch of the latest vX.Y.Z tag (0.1.0 if none)
#   just release 1.2.3     -> release exactly that version
release version="":
    #!/usr/bin/env bash
    set -euo pipefail
    git fetch --tags --quiet
    ver="{{version}}"
    if [ -z "$ver" ]; then
        last=$(git tag -l 'v*' --sort=-v:refname | head -n1)
        if [ -z "$last" ]; then
            ver="0.1.0"
        else
            base=${last#v}
            IFS='.' read -r MA MI PA <<<"$base"
            ver="${MA:-0}.${MI:-0}.$(( ${PA:-0} + 1 ))"
        fi
    fi
    ver=${ver#v}
    tag="v${ver}"
    if git rev-parse "$tag" >/dev/null 2>&1; then
        echo "tag $tag already exists — pick another version" >&2
        exit 1
    fi
    branch=$(git rev-parse --abbrev-ref HEAD)
    echo "Releasing $tag from $branch @ $(git rev-parse --short HEAD)"
    git tag -a "$tag" -m "release $tag"
    git push origin "$tag"
    echo "Pushed $tag — GitHub Actions will build and publish the release."
