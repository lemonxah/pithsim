# pith-hb-firmware tasks (Rust / esp-idf). Run `just` to list.
# Source the esp env first:  source ~/export-esp.sh
set shell := ["bash", "-uc"]

default:
    @just --list

# Build the firmware (debug).
build:
    cargo build

# Build optimized.
release-build:
    cargo build --release

# Build + flash bootloader + OUR partition table (dual OTA slots) + app in
# one shot. Put the board into ROM download mode first: hold BOOT, tap RESET.
# This is also the one-time migration from the old single-factory layout —
# after it, updates go over USB HID (@OTA) from the dashboard.
flash port="":
    cargo build --release
    espflash flash --partition-table partitions.csv \
        {{ if port != "" { "-p " + port } else { "" } }} \
        target/xtensa-esp32s2-espidf/release/pith-hb

# Save the app image (what the dashboard streams over @OTA) and the full
# merged image (bootloader + partition table + app, written at 0x0 in ROM
# download mode — the recovery/migration path).
image:
    cargo build --release
    espflash save-image --chip esp32s2 \
        target/xtensa-esp32s2-espidf/release/pith-hb pith-hb-lolin_s2_mini.bin
    espflash save-image --chip esp32s2 --merge --partition-table partitions.csv \
        target/xtensa-esp32s2-espidf/release/pith-hb pith-hb-lolin_s2_mini-full.bin

# Serial monitor only (UART0 console — the USB port is owned by CDC+HID).
monitor port="":
    espflash monitor {{ if port != "" { "-p " + port } else { "" } }}

# ---- ESP32-S3 board variant ----
# S2 and S3 are different Xtensa targets, so the S3 build needs an explicit
# --target + MCU override (CARGO_BUILD_TARGET/MCU env vars beat the
# .cargo/config.toml defaults, which stay S2 since that's the shipped
# hardware) plus --features esp32s3 to label @CAP's board string correctly.

build-s3:
    CARGO_BUILD_TARGET=xtensa-esp32s3-espidf MCU=esp32s3 \
        cargo build --features esp32s3 --no-default-features

flash-s3 port="":
    CARGO_BUILD_TARGET=xtensa-esp32s3-espidf MCU=esp32s3 \
        cargo build --release --features esp32s3 --no-default-features
    espflash flash --partition-table partitions.csv \
        {{ if port != "" { "-p " + port } else { "" } }} \
        target/xtensa-esp32s3-espidf/release/pith-hb

image-s3:
    CARGO_BUILD_TARGET=xtensa-esp32s3-espidf MCU=esp32s3 \
        cargo build --release --features esp32s3 --no-default-features
    espflash save-image --chip esp32s3 \
        target/xtensa-esp32s3-espidf/release/pith-hb pith-hb-esp32s3_devkit.bin
    espflash save-image --chip esp32s3 --merge --partition-table partitions.csv \
        target/xtensa-esp32s3-espidf/release/pith-hb pith-hb-esp32s3_devkit-full.bin
