# --- pith-hb defaults (ESP32-S2, Rust build) ---

# Console on UART0: the native USB-OTG peripheral is owned by our TinyUSB
# composite device (CDC + HID) and S2 has no separate USB-Serial-JTAG
# peripheral to fall back on, so console can't use USB. Attach a 3.3V
# USB-UART adapter to UART0 to see logs.
CONFIG_ESP_CONSOLE_UART_DEFAULT=y

# 4 MB flash (Lolin S2 Mini) with a custom partition table: nvs + dual OTA
# app slots. The dashboard updates the device in place over HID (@OTA);
# espflash in ROM download mode (hold BOOT, tap RESET) is the recovery path
# and the one-time migration from the old single-factory layout.
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# Compile the ESP-IDF C side (FreeRTOS, drivers, TinyUSB) for speed — the USB
# device task and GPIO bit-banging for the HX711 live there.
CONFIG_COMPILER_OPTIMIZATION_PERF=y

# A failed boot after an OTA rolls back to the previous slot; the running
# image confirms itself via esp_ota_mark_app_valid_cancel_rollback().
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y
