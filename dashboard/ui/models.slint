// Shared structs, enums and global singletons. C++ owns the data and writes
// these globals; the UI reads them and invokes callbacks for actions.

export enum Page { overview, race, shift, cars, udp, firmware, wireless, device, handbrake, pedals }

// ---- Telemetry (live device mirror) ----
export struct TyreCell { temp: int, col: color }

export global Telemetry {
    in property <bool> connected: false;
    in property <string> game: "—";          // iRacing / ACC / Le Mans Ultimate / rFactor 2
    in property <float> hz: 0;

    in property <string> gear: "N";
    in property <int> speed: 0;               // already in display units
    in property <string> speed-unit: "KM/H";
    in property <int> rpm: 0;
    in property <int> redline: 8200;

    in property <float> delta: 0.0;           // seconds, +behind / -ahead
    in property <int> position: 1;
    in property <int> field-size: 20;

    in property <float> fuel: 0.0;            // litres
    in property <int> lap-num: 0;
    in property <string> cur-lap: "--:--.---";
    in property <string> best-lap: "--:--.---";
    in property <string> last-lap: "--:--.---";
    in property <int> water-c: 0;
    in property <int> oil-c: 0;
    in property <float> brake-bias: 0.0;      // % front
    in property <int> tc: 0;
    in property <int> abs: 0;
    in property <string> flag: "";            // green/yellow/blue/white/...

    in property <[TyreCell]> tyres: [
        { temp: 0, col: #2E9DFF }, { temp: 0, col: #2E9DFF },
        { temp: 0, col: #2E9DFF }, { temp: 0, col: #2E9DFF } ];

    // 12 LED colours for the current rpm/gear (off = transparent-ish #0c0d10)
    in property <[color]> leds: [
        #0c0d10, #0c0d10, #0c0d10, #0c0d10, #0c0d10, #0c0d10,
        #0c0d10, #0c0d10, #0c0d10, #0c0d10, #0c0d10, #0c0d10 ];
    in property <bool> redline-active: false;  // drives blink in previews
}

// ---- Telemetry UDP server (direct game decoders + SimHub plugin over UDP) ----
export global TelemetryUdp {
    in-out property <int> port: 28909;          // bind port (editable)
    in property <bool> listening: false;        // socket bound OK?
    in property <int> bound-port: 0;            // port the socket is actually bound to
    in property <int> packets: 0;               // total datagrams accepted
    in property <int> pps: 0;                   // datagrams/second (live)
    in property <string> last-source: "";       // joined live sources (for highlights)
    in property <[string]> sources: [];         // every live feed, one per line
    in property <string> local-ip: "";          // this PC's LAN IP (point the game here)
    in property <[string]> supported: [];       // directly-decoded games

    callback set-port(int);

    // ---- active connectors (we reach out to the game) ----
    // ACC broadcasting (auto-connects when ACC is detected running).
    in-out property <bool> acc-on: true;
    in-out property <string> acc-host: "127.0.0.1";
    in-out property <int> acc-port: 9000;
    in-out property <string> acc-password: "asd";
    in property <string> acc-status: "Off";
    callback set-acc(bool /*on*/, string /*host*/, int /*port*/, string /*password*/);

    // Assetto Corsa (original) handshake (auto-connects when AC is detected).
    in-out property <bool> ac-on: true;
    in-out property <string> ac-host: "127.0.0.1";
    in-out property <int> ac-port: 9996;
    in property <string> ac-status: "Off";
    callback set-ac(bool, string, int);

    // Gran Turismo 7 / Sport (manual: needs the console's IP).
    in-out property <bool> gt7-on: false;
    in-out property <string> gt7-host: "";
    in property <string> gt7-status: "Off";
    callback set-gt7(bool, string);

    // Native shared-memory reader (Linux /dev/shm, e.g. AC/ACC via a bridge).
    in-out property <bool> shm-on: true;
    in property <string> shm-status: "Off";
    callback set-shm(bool);
}

// ---- Shift lights config (§5) ----
export struct Led { col: color, threshold: int }   // threshold = % of redline

export global ShiftCfg {
    in-out property <int> redline-rpm: 8200;
    in-out property <int> first-led-pct: 62;
    in-out property <bool> blink-enabled: true;
    in-out property <float> blink-hz: 5.0;
    in-out property <int> animation: 0;        // 0 L→R, 1 Center, 2 Edges
    in-out property <int> brightness: 80;
    in-out property <int> rpm-source: 0;       // 0 = car library, 1 = custom
    in-out property <int> sel-gear: 1;         // 1..6
    // 12 LEDs for the selected gear (C++ swaps this when sel-gear changes)
    in-out property <[Led]> leds: [
        { col: #00E676, threshold: 62 }, { col: #00E676, threshold: 66 },
        { col: #00E676, threshold: 70 }, { col: #00E676, threshold: 74 },
        { col: #FFB300, threshold: 78 }, { col: #FFB300, threshold: 82 },
        { col: #FFB300, threshold: 85 }, { col: #FFB300, threshold: 88 },
        { col: #FF3B30, threshold: 91 }, { col: #FF3B30, threshold: 94 },
        { col: #FF3B30, threshold: 97 }, { col: #FF3B30, threshold: 99 } ];

    in property <string> car-name: "Porsche 911 GT3 R";
    in property <string> car-game: "iRacing";

    callback select-gear(int);
    callback set-led-threshold(int /*idx*/, int /*pct*/);
    callback set-led-color(int /*idx*/, color);
    callback save();
    callback persist();   // remember the on-screen settings locally (no device push)
}

// ---- Touchscreen buttons (§4) ----
export struct DashButton {
    pos: int,
    label: string,
    is-toggle: bool,
    is-on: bool,
    action: string,
    active-col: color,
    sync-from-game: bool,
    game-field: string,
    field-available: bool,
    field-idx: int,    // index into Buttons.field-options for the ComboBox
}

export global Buttons {
    in-out property <int> page: 0;            // active page index
    in-out property <int> page-count: 3;      // 1..5 pages
    in-out property <[int]> page-list: [0, 1, 2];  // [0..page-count-1] for the tab loop
    in-out property <int> sel: 0;             // selected tile 0..5
    in-out property <[DashButton]> tiles: []; // the active page's 6 tiles
    in-out property <[string]> actions: [];   // bound-action dropdown options
    in-out property <[string]> field-options: [];  // reported game fields to bind toggles to
    in-out property <string> save-status: "";       // push result feedback

    callback select-tile(int /*page*/, int /*pos*/);
    callback set-label(string);
    callback set-kind(bool /*toggle*/);
    callback set-action(string);
    callback set-sync(bool);
    callback set-field(string);
    callback set-color(color);
    callback add-page();
    callback delete-page(int);
    callback select-page(int);
    callback save();
}

// ---- Race layout: the dumbed-down layout language (§3) ----
// A race screen = zones, each holding an ordered list of modules. A module has a
// stable id (unique instance), a type (what it draws), a display name and on/off.
// Authoring view of a module: identity + the full editable design-language spec.
export struct ZoneModule {
    id: string, type: string, name: string, enabled: bool,
    kind: string, field: string, label: string, unit: string,
    fmt: string, scale: int, base: string, rule-summary: string,
    size: int,   // text size as % of box height (0 = auto-fit)
    x: int, y: int, w: int, h: int,   // freeform rect (device px)
    // button nodes: HID joystick button (1..32) + latch/momentary
    toggle: bool, hid: int,
    page: int,   // tab page this node is on (when the display is tabbed)
    // option-list indices for ComboBox current-index (Slint ignores current-value writes)
    kind-idx: int, field-idx: int, fmt-idx: int, base-idx: int, on-base-idx: int,
    // resolved swatch colours for the colour-picker fields (named or custom RGB)
    base-color: color, on-base-color: color,
}

// One freeform node overlay drawn on top of the pith-ui preview image. The
// pixels come from the image; this is just the interactive selection/drag box.
export struct NodeBox {
    id: string, x: int, y: int, w: int, h: int,   // device px
    kind: string, label: string, selected: bool,
}

// A device-pixel point (used as the snapped drag delta returned by node-snap).
export struct Pt { x: int, y: int }
// Normalized (0..1) force-curve control point, x = travel, y = force.
export struct CurvePt { x: float, y: float }
// A saved pedal profile: its name + the game/car binding keys it auto-applies
// for (comma-separated sim-id / car-substring keys, empty = manual only).
export struct PedalProfile { name: string, binding: string }
// One known sim in the binding editor's game-chip row; `on` = the active
// profile's binding already carries this game's key.
export struct GameOpt { name: string, id: string, on: bool }

// One element inside the selected widget's tree (list row + inline editor fields).
export struct ElemRow {
    idx: int, kind: string, summary: string, selected: bool,
    flex: int, field: string, text: string, base: string, size: int,
    align: int, valign: int, action: string,
    toggle: bool, hid: int,
    kind-idx: int, field-idx: int, base-idx: int,
}
export struct LayoutZone { key: string, title: string, modules: [ZoneModule] }
export struct PresetCard { name: string, summary: string, active: bool, builtin: bool }
export struct ModuleDef { type: string, name: string, desc: string }   // catalog entry

// One color rule (op value -> color token) for the module edit panel.
export struct RuleRow { op: string, v: int, color: string, op-idx: int, color-idx: int }

// A module fully RESOLVED by C++ for the preview: value text + color already
// computed from the same field registry + format_common + palette the device
// uses, so the preview renders identically to the device.
export struct ResolvedModule {
    zone: string, order: int, kind: string,
    label: string, value: string, value-col: color, pct: int, enabled: bool,
    size: int,   // text size % (0 = auto)
}
export struct ResolvedZone { key: string, modules: [ResolvedModule] }

export global RaceLayout {
    in-out property <[PresetCard]> presets: [];
    in-out property <[LayoutZone]> zones: [];           // authoring model
    in-out property <[ResolvedZone]> render-zones: [];  // resolved preview model
    in property <image> preview-image;                  // pith-ui rendered mirror (pixel-identical to device)
    in-out property <[NodeBox]> nodes: [];              // freeform node overlays (current display)
    in-out property <int> edit-display: 0;             // which display the editor is showing (0/1)
    in property <int> display-count: 1;                // # of displays the device exposes
    // tab pages for the current display (empty = not tabbed). Buttons/widgets are
    // assigned to a page; the device shows a tab strip + the active page.
    in-out property <[string]> tab-names: [];
    in-out property <int> edit-tab: 0;                  // tab page shown in the editor
    callback tabs-enable(bool);                         // turn tabbing on/off for the current display
    callback tab-add();
    callback tab-rename(int /*idx*/, string);
    callback tab-remove(int /*idx*/);
    callback tab-move(int /*idx*/, int /*dir: -1 left, +1 right*/); // reorder tab pages
    callback tab-select(int /*idx*/);
    callback set-mod-page(int /*tab page for the selected node*/);
    // track map: which bundled track outline the Map widget shows (baked into @UI)
    in-out property <[string]> map-tracks: [];
    in-out property <int> map-track-idx: 0;
    callback set-map-track(string);
    in-out property <[ModuleDef]> catalog: [];          // module templates you can add
    in property <string> main-res: "480×320";           // main display resolution (from caps)
    in-out property <bool> dirty: false;                // unsaved changes
    in-out property <string> save-status: "";           // last push result (feedback)

    // ---- module edit panel (the selected module's spec) ----
    in-out property <string> sel-zone: "";
    in-out property <string> sel-id: "";
    in-out property <bool> dragging: false;   // true while a module is being dragged (disables list scroll)
    in-out property <ZoneModule> edit;                  // selected module's spec
    in-out property <[RuleRow]> edit-rules: [];
    in-out property <[string]> field-options: [];       // bindable telemetry fields
    in-out property <[string]> kind-options: [];
    in-out property <[string]> palette-options: [];
    in-out property <[color]> palette-colors: [];        // swatch colours parallel to palette-options
    in-out property <[color]> theme-swatches: [];        // saved custom colours (swatch)
    in-out property <[string]> theme-swatch-hexes: [];   // "#rrggbb" parallel to theme-swatches
    in-out property <[string]> fmt-options: [];

    callback select-preset(int);
    callback new-preset(string /*name*/);               // snapshot current zones as a preset
    callback update-preset();                           // save current edits into the active preset (persists)
    callback delete-preset(int);
    callback toggle-module(string /*zoneKey*/, string /*moduleId*/, bool);
    callback add-module(string /*zoneKey*/, string /*moduleType*/);
    callback remove-module(string /*zoneKey*/, string /*moduleId*/);
    callback move-module(string /*zoneKey*/, int /*from*/, int /*to*/);
    callback select-module(string /*zoneKey*/, string /*moduleId*/);
    callback set-mod-kind(string);
    callback set-mod-field(string);
    callback set-mod-label(string);
    callback set-mod-unit(string);
    callback set-mod-fmt(string);
    callback set-mod-base(string);      // accepts a palette name OR "#rrggbb"
    callback set-mod-on-base(string);   // accepts a palette name OR "#rrggbb"
    callback save-theme-swatch(string); // remember a custom "#rrggbb" in the palette
    callback set-mod-size(int);
    callback set-mod-toggle(bool);   // button node: latch vs momentary
    callback set-mod-hid(int);       // button node: HID joystick button 1..32
    callback add-rule();
    callback set-rule(int /*idx*/, string /*op*/, string /*v*/, string /*color*/);
    callback remove-rule(int /*idx*/);
    callback save();
    callback read-device();   // pull the active layout back from the device (@RG)
    // --- freeform editor ---
    callback node-select(string /*id*/);
    callback node-add(string /*type*/);                 // add a node to the current display
    callback add-button-grid();                         // 3×3 buttons filling the tab's content area
    callback node-remove(string /*id*/);
    callback delete-selected();                         // Delete key: drop the selected element, else the selected widget
    callback node-drag-start(string /*id*/);            // begin a move/resize gesture
    callback node-move(int /*dx*/, int /*dy*/);         // device-px delta from gesture start
    callback node-resize(int /*dw*/, int /*dh*/);       // device-px size delta from gesture start
    callback node-drag-end();                           // commit + persist
    callback set-node-geo(int /*x*/, int /*y*/, int /*w*/, int /*h*/);  // precise numeric placement
    callback switch-display(int);
    // snap-to-guides while dragging: returns the snapped delta from the gesture
    // start (device px); also publishes the active guide lines below.
    callback node-snap(int /*raw-dx*/, int /*raw-dy*/) -> Pt;
    in-out property <int> snap-vx: -1;   // active vertical guide (device x, -1 = none)
    in-out property <int> snap-hy: -1;   // active horizontal guide (device y, -1 = none)
    // alignment of the selected node against the canvas / other nodes
    callback node-center();      // centre on the screen (both axes)
    callback node-center-h();    // centre horizontally (screen X)
    callback node-center-v();    // centre vertically (screen Y)
    callback node-align-h();     // align Y to the nearest other node (a row)
    callback node-align-v();     // align X to the nearest other node (a column)
    // --- widget tree editor (the selected widget's internal elements) ---
    in-out property <bool> widget-custom: false;   // selected widget is a custom tree
    in-out property <int> widget-dir: 0;           // root layout: 0 = column, 1 = row
    in-out property <int> widget-gap: 4;
    in-out property <[ElemRow]> elems: [];         // elements of the selected widget
    in-out property <int> sel-elem: -1;
    in-out property <[string]> elem-kinds: [];     // element types you can add
    callback widget-customize();                   // seed the tree from the built-in
    callback widget-reset();                       // back to the built-in (clear the tree)
    callback set-widget-dir(int);
    callback set-widget-gap(int);
    callback elem-add(string /*kind*/);
    callback elem-remove(int /*idx*/);
    callback elem-move(int /*idx*/, int /*dir: -1 up / +1 down*/);
    callback elem-select(int /*idx*/);
    callback set-elem-kind(string);
    callback set-elem-field(string);
    callback set-elem-text(string);
    callback set-elem-base(string);
    callback set-elem-size(int);
    callback set-elem-align(int);
    callback set-elem-valign(int);
    callback set-elem-flex(int);
    callback set-elem-action(string);
    callback set-elem-toggle(bool);  // button element: latch vs momentary
    callback set-elem-hid(int);      // button element: HID joystick button 1..32
}

// ---- Car library / lovely-car-data (§6) ----
export struct CarRow {
    id: string,
    badge: string,
    name: string,
    make: string,
    klass: string,
    year: int,
    power: string,
    redline: int,
    active: bool,
    leds: [color],     // shift-light colours from lovely-car-data (preview)
}

export global CarLib {
    in-out property <[string]> games: ["iRacing", "ACC", "Le Mans Ultimate", "Automobilista 2"];
    in property <bool> have-db: false;        // local DB downloaded?
    in property <string> db-info: "";         // e.g. "684 cars · cached"
    in-out property <int> game: 0;
    in-out property <string> query: "";
    in-out property <[string]> classes: ["All classes", "GT3", "GT4", "Cup", "Road"];
    in-out property <int> klass: 0;
    in-out property <[CarRow]> results: [];
    in-out property <int> total-cars: 0;
    in-out property <int> sel: -1;        // selected result index
    in property <bool> loading: false;
    in property <string> status: "";
    in property <bool> downloading: false;         // bulk dataset download in progress
    in property <float> download-progress: 0.0;    // 0..1 for the progress bar
    in-out property <string> detected-game: "";   // sim detected running (auto-selected)
    in-out property <string> detected-car: "";     // car model reported by SimHub (CarModel)

    callback select-game(int);
    callback set-query(string);
    callback select-class(int);
    callback select-car(int);
    callback set-active(int);
    callback apply-redline(int);          // -> Shift Lights
    callback refresh();
}

// ---- Firmware (§8) ----
export enum FwState { idle, available, downloading, verifying, flashing, success, failure }
export struct FwComponent { name: string, version: string, updating: bool, target: string }

export global Firmware {
    in property <bool> update-available: false;
    in property <string> current: "—";       // version reported by the connected device (@CAP)
    in property <string> latest: "—";         // version this app can build/flash
    in property <string> release-date: "—";
    in property <string> size: "—";
    in property <[string]> notes: [];
    in property <[FwComponent]> components: [];
    in-out property <bool> auto-install: false;
    in property <FwState> state: FwState.idle;
    in property <float> progress: 0;       // 0..1
    in property <string> status-line: "";
    in-out property <string> bin-path: "";  // local firmware .bin to OTA-flash
    in property <bool> have-bin: false;     // a build/pithddu.bin exists on disk

    // ---- firmware build (pick a board + compile the .bin locally) ----
    in property <bool> can-build: false;    // ESP-IDF toolchain detected -> build is possible
    in property <bool> building: false;     // a build is in progress
    in property <float> build-progress: 0;  // 0..1 (parsed from ninja [n/total])
    in property <string> build-status: "";  // one-line result/feedback
    in property <string> build-log: "";     // tail of the build output

    // ---- published firmware releases (GitHub) — pick a version to flash ----
    in property <[string]> releases: [];        // version tags, newest first ("v0.9.2 · 4 boards")
    in-out property <int> sel-release: 0;        // selected release index
    in property <string> releases-status: "";    // fetch/flash feedback
    in property <bool> release-has-board: false; // selected release has a build for the current board
    in property <bool> latest-has-board: false;  // newest release has a build for the current board
    in property <bool> fetching-releases: false;

    callback refresh-releases();
    callback select-release(int);
    callback flash-release();   // download the selected version's bin for the board + OTA it

    // ---- initial / full-image flash over USB serial (no PithDDU running yet) ----
    in property <[string]> serial-ports: [];   // "/dev/ttyACM0 · Espressif · ESP32-S3" labels
    in property <int> esp-port-count: 0;        // how many look like a flashable ESP32
    in-out property <int> serial-port: 0;       // selected port index
    in-out property <bool> full-image: true;    // include bootloader + partition table (first setup)
    in property <bool> flashing-serial: false;
    in property <float> serial-progress: 0;
    in property <string> serial-status: "";
    in property <string> serial-log: "";

    callback install();
    callback retry();
    callback build();           // compile firmware for the board selected in DeviceCfg
    callback cancel-build();
    callback flash-built();     // OTA-flash the freshly built bin (same as install)
    callback refresh-ports();   // re-scan serial ports
    callback serial-flash();    // build + flash the selected board over the selected port
}

// ---- Device config: GPIO pin layout (pushed to the device, applied on reboot) ----
export struct PinRow { key: string, label: string, gpio: int, opt-idx: int }
export global DeviceCfg {
    in-out property <[PinRow]> pins: [];
    in-out property <[string]> pin-options: [];   // selected board's silkscreen pin names
    in-out property <[string]> boards: [];        // supported board names
    in-out property <int> board: 0;               // selected board index
    in-out property <int> race-screen: 0;     // which display index shows the race screen (other = buttons)
    // LED strip (order on the chain: rev/shift, then TC, then ABS)
    in-out property <int> led-rev: 12;
    in-out property <int> led-tc: 2;
    in-out property <int> led-abs: 2;
    in-out property <bool> led-rgbw: true;    // SK6812 RGBW vs WS2812 RGB
    in-out property <string> pins-status: "";
    // Display orientation (applied live via @DO, no reboot — for differently-
    // mounted panels). rot index 0..3 = 0/90/180/270°.
    in-out property <int> disp-rot: 3;
    in-out property <bool> disp-flip-h: true;
    in-out property <bool> disp-flip-v: false;
    in-out property <bool> disp-bgr: true;     // BGR colour order (reboots on change)
    in-out property <bool> disp-inv: false;    // invert colours (reboots on change)
    callback set-pin(string /*key*/, int /*option-index*/);
    callback set-board(int);
    callback set-race-screen(int);
    callback set-led-rev(int);
    callback set-led-tc(int);
    callback set-led-abs(int);
    callback set-led-rgbw(bool);
    callback set-disp(int /*rot*/, bool /*flip-h*/, bool /*flip-v*/, bool /*bgr*/, bool /*inv*/);  // push @DO
    callback save-pins();        // push @PINS — the device reboots to apply
}

// ---- Device capabilities (reported by the device on connect, §handshake) ----
export struct ScreenSpec { role: string, w: int, h: int, touch: bool }

export global DeviceCaps {
    in property <bool> known: false;
    in property <[ScreenSpec]> screens: [];   // labelled main / side
    in property <string> main-res: "—";       // e.g. "480×320"
    in property <string> side-res: "—";
    in property <int> main-w: 480;            // numeric dims for sizing previews
    in property <int> main-h: 320;
    in property <int> side-w: 480;
    in property <int> side-h: 320;
    in property <int> rev-leds: 0;            // shift / rev LEDs
    in property <int> tc-leds: 0;             // traction-control side LEDs
    in property <int> abs-leds: 0;            // ABS side LEDs
    in property <bool> separate-strip: true;  // shift strip distinct from TC/ABS
    in property <int> button-pages: 3;        // button pages on the side screen
    in property <string> summary: "";
}

// ---- App-wide state + device actions ----
export global AppState {
    in-out property <Page> page: Page.overview;
    in property <string> device-name: "Pith DDU";
    in property <string> fw-version: "";   // set from the DDU's @CAP on connect
    in property <bool> connected: false;
    in property <string> conn-detail: "Disconnected";
    in property <int> health-pct: 0;
    in property <string> serial: "";       // device serial number (from @CAP)
    in property <string> sync-status: "";  // transient feedback for the "Sync device" pull
    in-out property <int> units: 0;        // 0 KM/H, 1 MPH
    in-out property <length> win-h;        // live window height (so popups can flip near the bottom)
    in-out property <bool> sim-on: false;  // "Simulate" test-feed toggle

    callback connect();
    callback disconnect();
    callback sync-device();
    callback simulate(bool /*on*/);        // start/stop the animated test telemetry feed
    callback minimize();
    callback close();
}

// Device-side log stream (firmware logs over HID report id 3), shown in the GUI.
export global DeviceLog {
    in property <[string]> lines;
    in property <string> text;      // all lines joined — for the selectable view + copy
    in property <int> count;        // total lines received
    callback clear();
    callback copy();                // copy the whole log to the clipboard
}

// ---- Handbrake (single-axis load-cell gear; its own device + connection) ----
// The handbrake page runs a self-contained wizard: connect -> auto-calibrate ->
// deadzone -> done, plus a live monitor. Rust's hb_device_loop owns the HID
// handle and mirrors state here; the sub-page routing below is independent of
// the app-level Page so the DDU pages are untouched by handbrake navigation.
export enum HbPage { connect, auto-calibrate, deadzone, done, monitor }

export global Hb {
    in-out property <HbPage> page: HbPage.connect;
    in property <bool> connected: false;
    in property <string> conn-detail: "";
    // Last command error (e.g. "span" when the learn window saw too little
    // movement), shown inline by whichever sub-screen triggered it.
    in property <string> error: "";

    // Live device mirror: the calibration currently in effect on the firmware
    // ("pending" — equal to the saved one except mid-wizard-edit) plus the
    // latest raw/output sample. Refreshed from a `?` status reply after every
    // command.
    in property <int> raw: 0;
    in property <int> pct-x10: 0;       // 0..1000, one implied decimal of percent
    in property <int> idle-raw: 0;
    in property <int> max-raw: 0;
    in property <int> deadzone-lo: 2;   // %
    in property <int> deadzone-hi: 2;   // %
    in property <bool> inverted: false;
    in property <bool> calibrated: false;
    in property <string> board: "";
    in property <string> fw-version: "";
    in property <string> serial: "";
    // Whether a handbrake is currently plugged in (HID presence check).
    // Connecting is fully automatic once this goes true — no button.
    in property <bool> device-found: false;

    // Auto-calibration: no idle/max button presses — move the handbrake
    // through its full range and the app learns the boundaries from the
    // observed min/max over a timed window.
    in property <bool> learn-active: false;
    in property <int> learn-min: 0;
    in property <int> learn-max: 0;
    in property <int> learn-remaining-s: 0;
    in property <float> learn-progress: 0; // 0..1, elapsed / total duration

    // Firmware updates: the handbrake's app image ships in the same
    // firmware-v* GitHub release as the DDU's (asset pith-hb-<board>.bin).
    // No OTA on this device — flashing goes over the ROM bootloader, so the
    // user puts it in download mode (hold BOOT, tap RESET) and the flash card
    // appears on the connect sub-screen while the bootloader port is present.
    in property <string> fw-latest: "";          // newest published version, e.g. "v0.11.0"
    in property <bool> update-available: false;  // fw-latest > connected fw-version
    in property <bool> bootloader-present: false; // ROM download-mode port detected
    in property <bool> flashing: false;
    in property <float> flash-progress: 0;       // 0..1 download+flash
    in property <string> flash-status: "";

    callback auto-cal-start-requested();
    callback auto-cal-cancel-requested();
    callback set-deadzone(int, int);
    callback set-inverted(bool);
    callback save-requested();
    callback cancel-requested();
    callback reset-requested();
    callback flash-latest-requested();
    // In-place update over USB HID (@OTA) — no bootloader dance needed.
    callback install-update-requested();
}

// ---- Active Pedal (SimHub-replacement effects engine + config) ----
// One connected pedal for now (see docs/pedals.md — Phase 1 proves the
// pipeline end to end; a full 3-pedal rig is the natural next step once
// this is validated on real hardware). The dashboard's effects engine
// (Rust, hb-style device loop) reads the live telemetry merge and streams
// PedalAction — this is what replaces the SimHub plugin's per-frame writes.
export global Pedals {
    in property <bool> connected: false;
    in property <bool> device-found: false;
    in property <string> conn-detail: "";
    in property <string> board: "";
    in property <string> fw-version: "";
    in property <string> serial: "";

    // Live device state (from `?`), refreshed periodically.
    in property <int> position-pct-x10: 0;
    in property <int> force-n-x10: 0;

    // ---- firmware updates (pedals-v* GitHub release stream) ----
    // All pedal boards run the same pith-pedals image; the connected pedal
    // reports its running version via caps, compared against the newest
    // published pedals-v* release. In-place update over USB HID (@OTA) — same
    // slot-flip-and-reboot path as the DDU/handbrake.
    in property <string> fw-latest: "";          // newest published version, e.g. "v0.1.1"
    in property <bool> update-available: false;   // fw-latest > connected fw-version
    in property <bool> flashing: false;
    in property <float> flash-progress: 0;        // 0..1 download + @OTA stream
    in property <string> flash-status: "";
    callback install-update-requested();

    // ---- multi-pedal (SimHub-style pedal selector) ----
    // A rig has up to three pedals (each its own board; role set by the
    // on-board DIP switch). One shared editor is rebound to the selected
    // role — 0=Clutch, 1=Brake, 2=Throttle — instead of three near-identical
    // pages. `pedal-connected[i]` marks roles with a live device.
    in-out property <int> selected-pedal: 1; // brake, the common default
    in property <[bool]> pedal-connected: [false, false, false];
    // Rust saves the editor into the old role's slot and loads the new one.
    callback select-pedal(int);

    // Effect gains — a working subset of PedalConfig for a first UI pass
    // (0..100 sliders map directly to the 0..100 config fields/percent
    // scales pith-pedals-core::protocol documents per field).
    in-out property <int> abs-frequency-hz: 12;
    in-out property <int> abs-amplitude: 0;      // kg/20 units, 0..100
    in-out property <int> rpm-amplitude-kg: 0;
    in-out property <int> g-multiplier: 0;       // percent
    in-out property <int> wheel-slip-amplitude: 0;
    in-out property <int> road-impact-multiplier: 0; // percent
    in-out property <int> virtual-mass-pct: 20;
    in-out property <int> virtual-damping-pct: 50;

    // ---- full effect parameters (rest of each reference effect tab) ----
    // ABS/TC: waveform (0 = sine, 1 = sawtooth), apply-by (0 = force, 1 =
    // travel), plus the bench "simulate" test that injects a fixed level.
    in-out property <int> abs-waveform: 0;
    in-out property <int> abs-apply-by: 0;
    in-out property <bool> simulate-abs: false;
    in-out property <int> simulate-abs-value: 0;
    // ENG/SPD (RPM) frequency sweep endpoints (Hz).
    in-out property <int> rpm-min-freq-hz: 0;
    in-out property <int> rpm-max-freq-hz: 0;
    // Bite point (clutch): fires as the pedal crosses `trigger`%.
    in-out property <bool> bite-point-enabled: false;
    in-out property <int> bite-point-trigger-pct: 0;
    in-out property <int> bite-point-amplitude: 0;
    in-out property <int> bite-point-freq-hz: 0;
    // G-force smoothing window + wheel-slip/impact frequencies/windows.
    in-out property <int> g-window: 0;
    in-out property <int> wheel-slip-freq-hz: 0;
    in-out property <int> road-impact-window: 0;
    // Four general-purpose custom vibration slots (amplitude% + frequency Hz).
    in-out property <int> custom-amp-1: 0;
    in-out property <int> custom-freq-1: 0;
    in-out property <int> custom-amp-2: 0;
    in-out property <int> custom-freq-2: 0;
    in-out property <int> custom-amp-3: 0;
    in-out property <int> custom-freq-3: 0;
    in-out property <int> custom-amp-4: 0;
    in-out property <int> custom-freq-4: 0;

    // ---- pedal dynamics (rest of the reference Dynamics tab) ----
    in-out property <int> coulomb-friction-0p1n: 0;
    in-out property <int> damping-progression-pct: 0;
    in-out property <int> endstop-travel-mm: 2;
    in-out property <int> endstop-stiffness-kg-mm: 10;

    // ---- pedal geometry / kinematics (mm) ----
    in-out property <int> length-a-mm: 0;
    in-out property <int> length-b-mm: 0;
    in-out property <int> length-d-mm: 0;
    in-out property <int> length-c-horizontal-mm: 0;
    in-out property <int> length-c-vertical-mm: 0;
    in-out property <int> length-travel-mm: 0;

    // ---- axis output ----
    // Cap on the game-facing joystick axis (percent of full range).
    in-out property <int> max-game-output-pct: 100;
    // Joystick axis source: 0 = force, 1 = travel.
    in-out property <int> axis-source: 0;

    // ---- calibration / servo / general ----
    in-out property <int> loadcell-rating-kg: 50;
    in-out property <bool> invert-loadcell: false;
    in-out property <bool> invert-motor-direction: false;
    in-out property <int> spindle-pitch-mm: 4;
    in-out property <int> servo-idle-timeout-s: 30;
    in-out property <bool> step-loss-recovery: true;
    in-out property <bool> crash-detection: true;
    in-out property <int> endstop-detection-threshold: 10;
    in-out property <int> min-force-for-effects-n: 5;
    in-out property <int> debug-flags: 0;

    // ---- signal filter (loadcell denoise + joystick smoothing) ----
    // Force filter model: 0 = const-velocity KF, 1 = const-accel KF,
    // 2 = exponential, 3 = raw passthrough.
    in-out property <int> kf-force-model-order: 1;
    in-out property <int> kf-force-model-noise: 10;
    in-out property <bool> kf-joystick-enabled: false;
    in-out property <int> kf-joystick-model-noise: 10;

    // Force-vs-travel curve — the dashboard's version of the SimHub plugin's
    // curve editor. Points are normalized 0..1 (x = travel, y = force);
    // `spline-commands` is the cubic-spline polyline as an SVG path string
    // (computed in Rust from the control points, viewbox 0..1) that the
    // editor's Path renders. Max-force/preload frame the vertical axis (kg),
    // pedal-start/end the usable travel window (percent).
    in property <[CurvePt]> curve-points: [{ x: 0, y: 0 }, { x: 1, y: 1 }];
    // Spline preview as an SVG path string in a 2.5×1 viewbox (x scaled by the
    // plot's 2.5:1 aspect, y flipped so force=1 is at the top). Built in Rust.
    in property <string> spline-commands: "";
    in-out property <int> max-force-kg: 60;
    in-out property <int> preload-kg: 0;
    in-out property <int> pedal-start-pct: 0;
    in-out property <int> pedal-end-pct: 100;
    // A drag moved control point `index` to normalized (x, y).
    callback curve-point-moved(int, float, float);
    // Right-click at normalized (x, y): add a point there, or remove the one
    // under the cursor if close — Rust decides.
    callback curve-right-click(float, float);
    // Index of the control point nearest normalized (x, y), for drag-grab.
    callback curve-nearest(float, float) -> int;
    // One of "linear" / "s-curve" / "exponent" / "logarithm".
    callback curve-preset(string);
    // Max-force / preload / travel-range edited via the sliders.
    callback curve-range-changed();

    in property <string> config-status: ""; // feedback after push-config

    // Named profiles — the dashboard's answer to the SimHub plugin's per-
    // game/per-car profile switching (host-side file, see dashboard/src/
    // pedals.rs). Loading a profile only updates the UI/edit fields — it
    // does NOT push to the device automatically, so switching profiles
    // never silently changes a connected device's live behavior; the user
    // still has to hit PUSH TO DEVICE.
    in-out property <string> profile-name: "";
    // Saved profiles with their game/car bindings, for the profile manager list.
    in property <[PedalProfile]> profile-list: [];
    // Name of the profile last loaded into the editor (highlighted in the list).
    in property <string> active-profile: "";
    // The running game's sim-id + car model (from telemetry detection), shown so
    // the user can one-click bind a profile to whatever's running right now.
    in property <string> detected-game: "";
    in property <string> detected-car: "";

    // Auto profile switching (SimHub parity): when on, the dashboard applies
    // the profile whose binding matches the running game/car (car matches win
    // over game matches — more specific).
    in-out property <bool> auto-switch: false;

    // ---- game/car binding editor for the selected profile ----
    // A binding is a set of keys: a game's sim-id links the profile to that
    // whole game; any other key links it to cars whose model name contains
    // it. Rust owns the store (pedals profile-bindings file) and pushes these
    // models; the UI only fires the callbacks below.
    in property <string> profile-bind: "";     // raw comma-joined keys (row preview)
    in property <[string]> bind-keys: [];       // the active profile's keys, as chips
    // Every known sim + whether it's linked, pre-split into chip rows so the
    // card never overflows (Slint has no wrapping flow layout).
    in property <[[GameOpt]]> bind-games: [];
    // Select a profile in the manager (loads its binding into the editor).
    callback select-profile(string);
    callback bind-toggle-game(string /*sim-id*/);   // link/unlink a game
    callback bind-add-car(string /*car substring*/);
    callback bind-remove-key(string);

    callback push-config-requested();
    callback refresh-config-requested();
    callback save-profile-requested(string);
    callback load-profile-requested(string);
    callback delete-profile-requested(string);
    callback set-auto-switch(bool);
}

// ---- Wireless (its own screen) ----
// One shared set of network credentials for ALL Pith devices (each is
// provisioned over its USB link via @WIFI and then remembers the network in
// NVS), plus a per-hardware wireless toggle. Backed by dashboard/src/wifi.rs
// (discovery + axis routing + DDU telemetry forwarding).
export global Wireless {
    // Shared network credentials (persisted locally — set them once).
    in-out property <string> ssid: "";
    in-out property <string> pass: "";
    in property <string> creds-status: "";
    callback save-credentials(string /*ssid*/, string /*pass*/);

    // Send the stored credentials to a device over its USB connection.
    // Feedback lands in the matching status line.
    callback provision-ddu();
    callback provision-hb();
    callback provision-pedal();
    in property <string> ddu-status: "";
    in property <string> hb-status: "";
    in property <string> pedal-status: "";

    // Per-hardware wireless modes (persisted):
    //  - DDU: forward live telemetry to wireless DDUs on the network, and/or
    //    route its touch buttons into the virtual joystick (its 32-button box).
    //  - Handbrake / pedals: route that kind's wireless axis into a software
    //    virtual joystick the game reads (off = the device's own USB HID axis;
    //    never both, to avoid double-reporting).
    in-out property <bool> ddu-enabled: true;
    in-out property <bool> ddu-input-enabled: false;
    in-out property <bool> hb-input-enabled: false;
    in-out property <bool> pedals-input-enabled: false;
    callback set-ddu-enabled(bool);
    callback set-ddu-input(bool);
    callback set-hb-input(bool);
    callback set-pedals-input(bool);

    // Discovered wireless devices, formatted "<kind>  <serial>  <ip>".
    in property <[string]> devices: [];
}
