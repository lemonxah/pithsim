// Bundle the three font families (HANDOFF.md §1 typography).
import "../fonts/Rajdhani-Medium.ttf";
import "../fonts/Rajdhani-SemiBold.ttf";
import "../fonts/Rajdhani-Bold.ttf";
import "../fonts/BarlowSemiCondensed-Regular.ttf";
import "../fonts/BarlowSemiCondensed-Medium.ttf";
import "../fonts/BarlowSemiCondensed-SemiBold.ttf";
import "../fonts/JetBrainsMono-Regular.ttf";
import "../fonts/JetBrainsMono-Medium.ttf";
import "../fonts/JetBrainsMono-Bold.ttf";
// Device fonts (GNU FreeFont) — used only in the simulated device screen so the
// preview matches what the firmware renders (LovyanGFX FreeMono/FreeSans).
import "../fonts/FreeMono.ttf";
import "../fonts/FreeSans.ttf";

import { Theme } from "theme.slint";
import { AppState, Page } from "models.slint";
import { TitleBar, Sidebar } from "components/chrome.slint";
import { OverviewScreen } from "screens/overview.slint";
import { RaceScreen } from "screens/race-screen.slint";
import { ShiftScreen } from "screens/shift-lights.slint";
import { CarsScreen } from "screens/car-library.slint";
import { UdpScreen } from "screens/udp.slint";
import { FirmwareScreen } from "screens/firmware.slint";
import { WirelessScreen } from "screens/wireless.slint";
import { DeviceConfigScreen } from "screens/device.slint";
import { HandbrakeScreen } from "screens/handbrake.slint";
import { PedalsScreen } from "screens/pedals.slint";

// Re-export globals so C++ can reach them via the generated header.
export { AppState, Telemetry, TelemetryUdp, ShiftCfg, Buttons, RaceLayout, CarLib, Firmware, DeviceCaps, DeviceCfg, DeviceLog, Hb, Pedals, Wireless } from "models.slint";

export component AppWindow inherits Window {
    title: "Pith Dashboard";
    icon: @image-url("../icon.png");
    default-font-family: Theme.body-font;
    background: Theme.bg;
    preferred-width: 1320px;
    preferred-height: 860px;
    min-width: 1120px;
    min-height: 700px;

    // publish the window height so dropdowns/popups can flip up near the bottom
    init => { AppState.win-h = self.height; }
    changed height => { AppState.win-h = self.height; }

    VerticalLayout {
        TitleBar { }
        HorizontalLayout {
            Sidebar { }
            Rectangle {
                // content router
                Rectangle {
                    background: Theme.bg;
                    if AppState.page == Page.overview: OverviewScreen { }
                    if AppState.page == Page.race: RaceScreen { }
                    if AppState.page == Page.shift: ShiftScreen { }
                    if AppState.page == Page.cars: CarsScreen { }
                    if AppState.page == Page.udp: UdpScreen { }
                    if AppState.page == Page.firmware: FirmwareScreen { }
                    if AppState.page == Page.wireless: WirelessScreen { }
                    if AppState.page == Page.device: DeviceConfigScreen { }
                    if AppState.page == Page.handbrake: HandbrakeScreen { }
                    if AppState.page == Page.pedals: PedalsScreen { }
                }
            }
        }
    }
}
