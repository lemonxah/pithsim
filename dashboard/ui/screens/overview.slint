// Overview / home (HANDOFF.md §9).
import { Theme } from "../theme.slint";
import { AppState, Page, Telemetry, ShiftCfg, Firmware, CarLib, DeviceCaps, RaceLayout, Hb, Pedals } from "../models.slint";
import { Card, PrimaryButton, Dot, Mono } from "../widgets.slint";

component QuickCard inherits Rectangle {
    callback clicked;
    background: Theme.panel;
    border-radius: Theme.radius-card;
    border-width: 1px;
    border-color: ta.has-hover ? Theme.line2 : Theme.line;
    animate border-color { duration: 100ms; }
    ta := TouchArea { clicked => { root.clicked(); } }
}

// One device's row in the overview device list: status dot + name, firmware,
// connection/status text, and a tap-through "Update" chip when one's available.
component DeviceRow inherits Rectangle {
    in property <bool> connected;
    in property <string> name;
    in property <string> firmware;   // "v0.10.11" or "—"
    in property <string> status;     // connection detail / role
    in property <bool> update-available: false;
    callback update-clicked();
    height: 46px;
    HorizontalLayout {
        spacing: 16px;
        // name
        HorizontalLayout {
            width: 210px;
            spacing: 9px;
            VerticalLayout { alignment: center; Dot { tint: root.connected ? Theme.green : Theme.text3; } }
            VerticalLayout {
                alignment: center;
                Text { text: root.name; color: root.connected ? Theme.text : Theme.text2; font-family: Theme.display-font; font-size: 14px; font-weight: 600; }
            }
        }
        // firmware
        VerticalLayout { alignment: center; width: 120px; Mono { text: root.firmware; color: root.connected ? Theme.text : Theme.text3; font-size: 14px; } }
        // status / connection
        VerticalLayout { alignment: center; horizontal-stretch: 1; Mono { text: root.status; color: Theme.text3; font-size: 13px; } }
        // update chip
        VerticalLayout {
            alignment: center;
            if root.update-available: Rectangle {
                width: chip.preferred-width + 22px;
                height: 26px;
                background: chipta.has-hover ? Theme.accent : Theme.accent-dim;
                border-radius: 7px;
                border-width: 1px;
                border-color: Theme.accent;
                chip := Text {
                    text: "Update →";
                    color: chipta.has-hover ? Theme.accent-text : Theme.accent;
                    font-size: 12px;
                    font-weight: 600;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }
                chipta := TouchArea { mouse-cursor: pointer; clicked => { root.update-clicked(); } }
            }
        }
    }
}

export component OverviewScreen inherits Rectangle {
    Flickable {
        VerticalLayout {
            padding: 24px;
            spacing: 16px;
            alignment: start;   // keep content pinned top-left (don't vertically center when short)
            // header
            HorizontalLayout {
                VerticalLayout {
                    alignment: center;
                    spacing: 3px;
                    Text { text: "Overview"; color: Theme.text; font-family: Theme.display-font; font-size: 24px; font-weight: 700; }
                    Text { text: "All your Pith gear at a glance"; color: Theme.text3; font-size: 13px; }
                }
                Rectangle { }
                HorizontalLayout {
                    spacing: 10px;
                    VerticalLayout {
                        alignment: center;
                        spacing: 2px;
                        PrimaryButton {
                            text: "SYNC FROM DEVICE";
                            enabled: AppState.connected;
                            clicked => { AppState.sync-device(); }
                        }
                        if AppState.sync-status != "": Text {
                            text: AppState.sync-status;
                            color: Theme.text3; font-size: 10px; horizontal-alignment: right;
                        }
                    }
                }
            }
            // device status list — one row per Pith device (DDU, handbrake, and
            // each connected pedal), each with its own firmware + update chip.
            Card {
                VerticalLayout {
                    padding: 16px;
                    spacing: 2px;
                    // column header
                    HorizontalLayout {
                        spacing: 16px;
                        padding-bottom: 6px;
                        Text { text: "DEVICE"; width: 210px; color: Theme.text3; font-family: Theme.display-font; font-size: 10.5px; letter-spacing: 1.2px; }
                        Text { text: "FIRMWARE"; width: 120px; color: Theme.text3; font-family: Theme.display-font; font-size: 10.5px; letter-spacing: 1.2px; }
                        Text { text: "STATUS"; horizontal-stretch: 1; color: Theme.text3; font-family: Theme.display-font; font-size: 10.5px; letter-spacing: 1.2px; }
                    }
                    Rectangle { height: 1px; background: Theme.line; }

                    // ---- display unit ----
                    DeviceRow {
                        name: AppState.device-name;
                        connected: AppState.connected;
                        firmware: AppState.connected && AppState.fw-version != "" ? AppState.fw-version : "—";
                        status: AppState.connected
                            ? AppState.conn-detail + "  ·  " + DeviceCaps.main-res
                            : "Disconnected";
                        update-available: Firmware.update-available;
                        update-clicked => { AppState.page = Page.firmware; }
                    }
                    Rectangle { height: 1px; background: Theme.line; }

                    // ---- handbrake ----
                    DeviceRow {
                        name: "Pith Handbrake";
                        connected: Hb.connected;
                        firmware: Hb.connected && Hb.fw-version != "" ? "v" + Hb.fw-version : "—";
                        status: Hb.connected ? "Connected" : (Hb.device-found ? "Detected…" : "Disconnected");
                        update-available: Hb.update-available;
                        update-clicked => { AppState.page = Page.firmware; }
                    }
                    Rectangle { height: 1px; background: Theme.line; }

                    // ---- active pedals: always all three roles (each pedal is
                    // its own board; role set by its DIP switch) ----
                    DeviceRow {
                        name: "Pith Pedal · Clutch";
                        connected: Pedals.pedal-connected[0];
                        firmware: Pedals.pedal-connected[0] && Pedals.fw-version != "" ? "v" + Pedals.fw-version : "—";
                        status: Pedals.pedal-connected[0] ? "Connected"
                            : (Pedals.device-found && !Pedals.connected ? "Detected…" : "Disconnected");
                        update-available: Pedals.pedal-connected[0] && Pedals.update-available;
                        update-clicked => { AppState.page = Page.firmware; }
                    }
                    Rectangle { height: 1px; background: Theme.line; }
                    DeviceRow {
                        name: "Pith Pedal · Brake";
                        connected: Pedals.pedal-connected[1];
                        firmware: Pedals.pedal-connected[1] && Pedals.fw-version != "" ? "v" + Pedals.fw-version : "—";
                        status: Pedals.pedal-connected[1] ? "Connected"
                            : (Pedals.device-found && !Pedals.connected ? "Detected…" : "Disconnected");
                        update-available: Pedals.pedal-connected[1] && Pedals.update-available;
                        update-clicked => { AppState.page = Page.firmware; }
                    }
                    Rectangle { height: 1px; background: Theme.line; }
                    DeviceRow {
                        name: "Pith Pedal · Throttle";
                        connected: Pedals.pedal-connected[2];
                        firmware: Pedals.pedal-connected[2] && Pedals.fw-version != "" ? "v" + Pedals.fw-version : "—";
                        status: Pedals.pedal-connected[2] ? "Connected"
                            : (Pedals.device-found && !Pedals.connected ? "Detected…" : "Disconnected");
                        update-available: Pedals.pedal-connected[2] && Pedals.update-available;
                        update-clicked => { AppState.page = Page.firmware; }
                    }
                }
            }
            // auto-detected running game (process scan) + car model (SimHub CarModel)
            Card {
                height: 64px;
                HorizontalLayout {
                    padding: 18px;
                    spacing: 28px;
                    VerticalLayout {
                        alignment: center;
                        spacing: 5px;
                        Text { text: "DETECTED GAME"; color: Theme.text3; font-family: Theme.display-font; font-size: 10.5px; letter-spacing: 1.2px; }
                        HorizontalLayout {
                            spacing: 7px;
                            VerticalLayout { alignment: center; Dot { tint: CarLib.detected-game != "" ? Theme.green : Theme.text3; } }
                            Text { text: CarLib.detected-game != "" ? CarLib.detected-game : "Not detected"; color: Theme.text; font-family: Theme.mono-font; font-size: 14px; vertical-alignment: center; }
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        spacing: 5px;
                        Text { text: "DETECTED CAR"; color: Theme.text3; font-family: Theme.display-font; font-size: 10.5px; letter-spacing: 1.2px; }
                        Text { text: CarLib.detected-car != "" ? CarLib.detected-car : "—"; color: Theme.text; font-family: Theme.mono-font; font-size: 14px; }
                    }
                    // live session flag (from the telemetry merge — shm is the
                    // flag source for AC/ACC; the broadcasting UDP has none)
                    VerticalLayout {
                        alignment: center;
                        spacing: 5px;
                        Text { text: "FLAG"; color: Theme.text3; font-family: Theme.display-font; font-size: 10.5px; letter-spacing: 1.2px; }
                        HorizontalLayout {
                            spacing: 7px;
                            VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 14px; height: 14px; border-radius: 3px;
                                    border-width: 1px;
                                    border-color: Theme.line2;
                                    background: Telemetry.flag == "green" ? #00E676
                                        : Telemetry.flag == "yellow" ? #FFB300
                                        : Telemetry.flag == "blue" ? #2E9DFF
                                        : Telemetry.flag == "white" ? #ECEFF4
                                        : Telemetry.flag == "checkered" ? #9AA3B2
                                        : Telemetry.flag == "black" ? #14161B
                                        : transparent;
                                }
                            }
                            Text {
                                text: Telemetry.flag != "" ? Telemetry.flag : "—";
                                color: Theme.text;
                                font-family: Theme.mono-font;
                                font-size: 14px;
                                vertical-alignment: center;
                            }
                        }
                    }
                    Rectangle { }
                }
            }
            // FULL race screen preview (tall, shows everything the device renders)
            QuickCard {
                height: 360px;
                clicked => { AppState.page = Page.race; }
                VerticalLayout {
                    padding: 16px;
                    spacing: 10px;
                    HorizontalLayout {
                        Text { text: "RACE SCREEN"; color: Theme.text3; font-family: Theme.display-font; font-size: 11px; letter-spacing: 1.2px; vertical-alignment: center; }
                        Rectangle { }
                        Mono { text: "Main · " + DeviceCaps.main-res; color: Theme.text3; font-size: 11px; }
                    }
                    Rectangle {
                        vertical-stretch: 1;
                        Rectangle {
                            width: 432px;
                            height: 288px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            background: #000000;
                            border-radius: 14px;
                            // the actual rendered layout (same pixel-exact pith-ui mirror
                            // the editor shows) — reflects the real device screen
                            Image {
                                x: 6px;
                                y: 6px;
                                width: parent.width - 12px;
                                height: parent.height - 12px;
                                source: RaceLayout.preview-image;
                                image-rendering: pixelated;
                            }
                        }
                    }
                }
            }
            // quick cards row
            HorizontalLayout {
                spacing: 16px;
                height: 168px;
                QuickCard {
                    clicked => { AppState.page = Page.race; }
                    VerticalLayout { padding: 16px; spacing: 8px;
                        Text { text: "BUTTONS"; color: Theme.text3; font-family: Theme.display-font; font-size: 11px; letter-spacing: 1.2px; }
                        Text { text: "Now widgets — place on any screen"; color: Theme.text2; font-size: 14px; }
                        Mono { text: "Race editor → Add → Button"; color: Theme.text3; font-size: 12px; }
                        Rectangle { }
                    }
                }
                QuickCard {
                    clicked => { AppState.page = Page.shift; }
                    VerticalLayout { padding: 16px; spacing: 10px;
                        Text { text: "SHIFT LIGHTS"; color: Theme.text3; font-family: Theme.display-font; font-size: 11px; letter-spacing: 1.2px; }
                        HorizontalLayout { spacing: 3px; height: 16px;
                            for l in ShiftCfg.leds: Rectangle { background: l.col; border-radius: 3px; } }
                        Mono { text: ShiftCfg.redline-rpm + " rpm redline"; color: Theme.text2; font-size: 13px; }
                        Rectangle { }
                    }
                }
                QuickCard {
                    clicked => { AppState.page = Page.cars; }
                    VerticalLayout { padding: 16px; spacing: 6px;
                        Text { text: "ACTIVE CAR"; color: Theme.text3; font-family: Theme.display-font; font-size: 11px; letter-spacing: 1.2px; }
                        Text { text: ShiftCfg.car-name; color: Theme.text; font-family: Theme.display-font; font-size: 17px; font-weight: 700; }
                        Text { text: ShiftCfg.car-game; color: Theme.text2; font-size: 13px; }
                        Rectangle { }
                        Mono { text: ShiftCfg.redline-rpm + " rpm"; color: Theme.accent-soft; font-size: 13px; }
                    }
                }
                QuickCard {
                    // Updates across ALL Pith devices — every device has its own
                    // firmware, so a single version number means nothing here.
                    property <int> updates: (Firmware.update-available ? 1 : 0)
                        + (Hb.update-available ? 1 : 0)
                        + (Pedals.update-available ? 1 : 0);
                    clicked => { AppState.page = Page.firmware; }
                    VerticalLayout { padding: 16px; spacing: 8px;
                        Text { text: "FIRMWARE"; color: Theme.text3; font-family: Theme.display-font; font-size: 11px; letter-spacing: 1.2px; }
                        Text {
                            text: updates == 0 ? "All devices up to date"
                                : updates == 1 ? "1 update available"
                                : "\{updates} updates available";
                            color: updates > 0 ? Theme.accent : Theme.text;
                            font-size: 14px;
                        }
                        HorizontalLayout { spacing: 7px;
                            Dot { tint: Telemetry.connected ? Theme.green : Theme.text3; }
                            Text { text: Telemetry.connected ? "Telemetry live" : "Idle"; color: Theme.text2; font-size: 13px; vertical-alignment: center; }
                        }
                        Rectangle { }
                    }
                }
            }
            Rectangle { height: 8px; }
        }
    }
}
