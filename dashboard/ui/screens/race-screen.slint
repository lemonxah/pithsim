// Race Screen layout editor — the layout language in action (HANDOFF.md §3).
// Presets apply zone configs; modules drag-reorder by their left handle, toggle,
// add from a per-zone palette, and the live 320×240 mirror reflects every change.
import { Theme } from "../theme.slint";
import { RaceLayout, Telemetry, PresetCard, ZoneModule, ModuleDef, RuleRow, DeviceCaps, NodeBox, Pt } from "../models.slint";
import { Card, PrimaryButton, GhostButton, Dot } from "../widgets.slint";
import { ComboBox, LineEdit, Button, Slider } from "std-widgets.slint";

// Edit panel for the selected module: field binding, label, format, color rules.
component EditPanel inherits Card {
    VerticalLayout {
        padding: 12px;
        spacing: 7px;
        HorizontalLayout {
            Text { text: "EDIT MODULE"; color: Theme.text2; font-family: Theme.display-font; font-size: 12px; font-weight: 600; letter-spacing: 1px; vertical-alignment: center; }
            Rectangle { }
            Text { text: RaceLayout.edit.kind; color: Theme.accent; font-family: Theme.mono-font; font-size: 11px; vertical-alignment: center; }
        }
        Text { text: "KIND"; color: Theme.text3; font-size: 10px; letter-spacing: 0.5px; }
        ComboBox { model: RaceLayout.kind-options; current-index: RaceLayout.edit.kind-idx; selected(v) => { RaceLayout.set-mod-kind(v); } }
        Text { text: "DATA FIELD"; color: Theme.text3; font-size: 10px; letter-spacing: 0.5px; }
        ComboBox { model: RaceLayout.field-options; current-index: RaceLayout.edit.field-idx; selected(v) => { RaceLayout.set-mod-field(v); } }
        HorizontalLayout {
            spacing: 8px;
            VerticalLayout { spacing: 3px; horizontal-stretch: 1;
                Text { text: "LABEL"; color: Theme.text3; font-size: 10px; }
                LineEdit { text: RaceLayout.edit.label; edited(t) => { RaceLayout.set-mod-label(t); } }
            }
            VerticalLayout { spacing: 3px; width: 88px;
                Text { text: "UNIT"; color: Theme.text3; font-size: 10px; }
                LineEdit { text: RaceLayout.edit.unit; edited(t) => { RaceLayout.set-mod-unit(t); } }
            }
        }
        HorizontalLayout {
            spacing: 8px;
            VerticalLayout { spacing: 3px; horizontal-stretch: 1;
                Text { text: "FORMAT"; color: Theme.text3; font-size: 10px; }
                ComboBox { model: RaceLayout.fmt-options; current-index: RaceLayout.edit.fmt-idx; selected(v) => { RaceLayout.set-mod-fmt(v); } }
            }
            VerticalLayout { spacing: 3px; horizontal-stretch: 1;
                Text { text: "BASE COLOR"; color: Theme.text3; font-size: 10px; }
                ComboBox { model: RaceLayout.palette-options; current-index: RaceLayout.edit.base-idx; selected(v) => { RaceLayout.set-mod-base(v); } }
            }
        }
        VerticalLayout { spacing: 3px;
            Text { text: "TEXT SIZE %  (0 = auto-fit to box)"; color: Theme.text3; font-size: 10px; }
            LineEdit { text: "\{RaceLayout.edit.size}"; input-type: number; edited(t) => { RaceLayout.set-mod-size(t.to-float()); } }
        }
        // precise placement (device px) — mirrors drag/resize on the canvas
        Text { text: "POSITION & SIZE (px)"; color: Theme.text3; font-size: 10px; letter-spacing: 0.5px; }
        HorizontalLayout {
            spacing: 6px;
            VerticalLayout { spacing: 2px; horizontal-stretch: 1; Text { text: "X"; color: Theme.text3; font-size: 9px; }
                LineEdit { text: "\{RaceLayout.edit.x}"; input-type: number; edited(t) => { RaceLayout.set-node-geo(t.to-float(), RaceLayout.edit.y, RaceLayout.edit.w, RaceLayout.edit.h); } } }
            VerticalLayout { spacing: 2px; horizontal-stretch: 1; Text { text: "Y"; color: Theme.text3; font-size: 9px; }
                LineEdit { text: "\{RaceLayout.edit.y}"; input-type: number; edited(t) => { RaceLayout.set-node-geo(RaceLayout.edit.x, t.to-float(), RaceLayout.edit.w, RaceLayout.edit.h); } } }
            VerticalLayout { spacing: 2px; horizontal-stretch: 1; Text { text: "W"; color: Theme.text3; font-size: 9px; }
                LineEdit { text: "\{RaceLayout.edit.w}"; input-type: number; edited(t) => { RaceLayout.set-node-geo(RaceLayout.edit.x, RaceLayout.edit.y, t.to-float(), RaceLayout.edit.h); } } }
            VerticalLayout { spacing: 2px; horizontal-stretch: 1; Text { text: "H"; color: Theme.text3; font-size: 9px; }
                LineEdit { text: "\{RaceLayout.edit.h}"; input-type: number; edited(t) => { RaceLayout.set-node-geo(RaceLayout.edit.x, RaceLayout.edit.y, RaceLayout.edit.w, t.to-float()); } } }
        }
        // (X/Y/W/H share a row; on a narrow window widen the dashboard so the
        // editor panel + canvas both fit — the window min-width is 1120px.)
        Text { text: "ALIGN ON SCREEN"; color: Theme.text3; font-size: 10px; letter-spacing: 0.5px; }
        HorizontalLayout {
            spacing: 4px;
            Button { text: "Centre"; clicked => { RaceLayout.node-center(); } }
            Button { text: "Centre H"; clicked => { RaceLayout.node-center-h(); } }
            Button { text: "Centre V"; clicked => { RaceLayout.node-center-v(); } }
        }
        HorizontalLayout {
            spacing: 4px;
            Button { text: "Align H →other"; clicked => { RaceLayout.node-align-h(); } }
            Button { text: "Align V →other"; clicked => { RaceLayout.node-align-v(); } }
        }
        HorizontalLayout {
            Text { text: "COLOR RULES"; color: Theme.text3; font-size: 10px; letter-spacing: 0.5px; vertical-alignment: center; }
            Rectangle { }
            Button { text: "+ rule"; clicked => { RaceLayout.add-rule(); } }
        }
        for r[i] in RaceLayout.edit-rules: HorizontalLayout {
            spacing: 6px;
            ComboBox { width: 60px; model: ["<", "<=", "==", ">=", ">"]; current-index: r.op-idx; selected(v) => { RaceLayout.set-rule(i, v, "\{r.v}", r.color); } }
            LineEdit { width: 62px; text: "\{r.v}"; input-type: number; edited(t) => { RaceLayout.set-rule(i, r.op, t, r.color); } }
            ComboBox { horizontal-stretch: 1; model: RaceLayout.palette-options; current-index: r.color-idx; selected(v) => { RaceLayout.set-rule(i, r.op, "\{r.v}", v); } }
            Button { text: "✕"; clicked => { RaceLayout.remove-rule(i); } }
        }
        Rectangle { height: 2px; }
        Button { text: "🗑  Remove widget"; clicked => { RaceLayout.node-remove(RaceLayout.sel-id); } }
    }
}

// A freeform node's interactive overlay, drawn on top of the pith-ui image. The
// pixels come from the image; this box only handles select / drag / resize.
component NodeOverlay inherits Rectangle {
    in property <NodeBox> node;
    in property <float> scale;   // device px -> screen px
    in property <length> ox;     // image origin within the canvas
    in property <length> oy;
    // local gesture offsets (screen px) so the box follows the cursor live without
    // a model rebuild (which would recreate this element and abort the gesture)
    property <length> ddx: 0;
    property <length> ddy: 0;
    property <length> dw: 0;
    property <length> dh: 0;
    property <Pt> snap-res;     // snapped drag delta returned by node-snap

    x: root.ox + node.x * root.scale * 1px + root.ddx;
    y: root.oy + node.y * root.scale * 1px + root.ddy;
    width: node.w * root.scale * 1px + root.dw;
    height: node.h * root.scale * 1px + root.dh;
    border-width: node.selected ? 2px : 1px;
    border-color: node.selected ? Theme.accent : #ffffff55;
    border-radius: 2px;
    background: node.selected ? #4da3ff1a : #ffffff08;

    // whole-box move
    move-ta := TouchArea {
        mouse-cursor: move;
        property <length> ax;
        property <length> ay;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                RaceLayout.node-select(node.id);
                RaceLayout.node-drag-start(node.id);
                self.ax = self.mouse-x;
                self.ay = self.mouse-y;
                root.ddx = 0; root.ddy = 0;
                RaceLayout.dragging = true;
            }
            if (e.kind == PointerEventKind.up) {
                RaceLayout.node-drag-end();
                root.ddx = 0; root.ddy = 0;
                RaceLayout.dragging = false;
            }
        }
        moved => {
            // Ask Rust to snap the raw delta to screen + element guides; follow the
            // snapped result so the box itself snaps live.
            root.snap-res = RaceLayout.node-snap(
                Math.round((self.mouse-x - self.ax) / 1px / root.scale),
                Math.round((self.mouse-y - self.ay) / 1px / root.scale));
            root.ddx = root.snap-res.x * root.scale * 1px;
            root.ddy = root.snap-res.y * root.scale * 1px;
        }
    }
    // resize handle (bottom-right corner)
    Rectangle {
        width: 13px;
        height: 13px;
        x: parent.width - self.width - 1px;
        y: parent.height - self.height - 1px;
        background: node.selected ? Theme.accent : #ffffff77;
        border-radius: 2px;
        rz := TouchArea {
            mouse-cursor: nwse-resize;
            property <length> ax;
            property <length> ay;
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down) {
                    RaceLayout.node-select(node.id);
                    RaceLayout.node-drag-start(node.id);
                    self.ax = self.mouse-x;
                    self.ay = self.mouse-y;
                    root.dw = 0; root.dh = 0;
                    RaceLayout.dragging = true;
                }
                if (e.kind == PointerEventKind.up) {
                    RaceLayout.node-drag-end();
                    root.dw = 0; root.dh = 0;
                    RaceLayout.dragging = false;
                }
            }
            moved => {
                root.dw = self.mouse-x - self.ax;
                root.dh = self.mouse-y - self.ay;
                RaceLayout.node-resize(Math.round(root.dw / 1px / root.scale), Math.round(root.dh / 1px / root.scale));
            }
        }
    }
}

export component RaceScreen inherits Rectangle {
    property <float> zoom: 1.0;     // preview zoom (1.0 = fit to stage)
    VerticalLayout {
        padding: 24px;
        spacing: 16px;
        // header
        HorizontalLayout {
            VerticalLayout {
                alignment: center;
                spacing: 3px;
                Text { text: "Race Screen Layout"; color: Theme.text; font-family: Theme.display-font; font-size: 24px; font-weight: 700; }
                Text { text: "Freeform pith-ui editor · Display " + (RaceLayout.edit-display + 1) + " · pixel-exact mirror"; color: Theme.text3; font-size: 13px; }
            }
            Rectangle { }
            HorizontalLayout {
                spacing: 10px;
                VerticalLayout { alignment: center;
                    if RaceLayout.dirty: Text { text: "unsaved"; color: Theme.amber; font-size: 12px; horizontal-alignment: right; }
                    if !RaceLayout.dirty && RaceLayout.save-status != "": Text {
                        text: RaceLayout.save-status;
                        color: (RaceLayout.save-status == "Not connected" || RaceLayout.save-status == "Device rejected — update firmware") ? Theme.red : Theme.green;
                        font-size: 12px; horizontal-alignment: right;
                    }
                }
                GhostButton { text: "READ FROM DEVICE"; clicked => { RaceLayout.read-device(); } }
                GhostButton { text: "SAVE PRESET"; clicked => { RaceLayout.update-preset(); } }
                PrimaryButton { text: "SAVE TO DEVICE"; clicked => { RaceLayout.save(); } }
            }
        }
        // preset rail (scrollable)
        Rectangle {
            height: 76px;
            preset-flick := Flickable {
                viewport-width: preset-row.preferred-width;
                viewport-height: self.height;
                preset-row := HorizontalLayout {
                    spacing: 12px;
                    for p[i] in RaceLayout.presets: Rectangle {
                        width: 168px;
                        background: p.active ? Theme.accent-dim : Theme.panel;
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: p.active ? Theme.accent : Theme.line;
                        VerticalLayout {
                            padding: 12px;
                            spacing: 4px;
                            alignment: center;
                            HorizontalLayout {
                                Text { text: p.name; color: p.active ? Theme.accent : Theme.text; font-family: Theme.display-font; font-size: 16px; font-weight: 700; }
                                Rectangle { }
                                if !p.builtin: TouchArea {
                                    width: 16px;
                                    Text { text: "✕"; color: delx.has-hover ? Theme.red : Theme.text3; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                                    delx := TouchArea { clicked => { RaceLayout.delete-preset(i); } }
                                }
                            }
                            Text { text: p.summary; color: Theme.text3; font-size: 11px; overflow: elide; }
                        }
                        TouchArea { clicked => { RaceLayout.select-preset(i); } }
                    }
                    // new preset (dashed)
                    Rectangle {
                        width: 140px;
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: Theme.line2;
                        Text { text: "+ New preset"; color: Theme.text3; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
                        TouchArea { clicked => { RaceLayout.new-preset("Custom " + (RaceLayout.presets.length + 1)); } }
                    }
                }
            }
        }
        // split body
        HorizontalLayout {
            spacing: 18px;
            // live preview stage
            Rectangle {
                horizontal-stretch: 1;
                background: @radial-gradient(circle, #14171c 0%, #0a0b0d 70%);
                border-radius: 12px;
                border-width: 1px;
                border-color: Theme.line;
                VerticalLayout {
                    padding: 22px;
                    spacing: 12px;
                    HorizontalLayout {
                        spacing: 10px;
                        HorizontalLayout {
                            spacing: 7px;
                            Dot { tint: Telemetry.connected ? Theme.green : Theme.text3; }
                            Text { text: Telemetry.connected ? "LIVE · " + Telemetry.game : "IDLE"; color: Theme.text2; font-family: Theme.display-font; font-size: 11px; letter-spacing: 1px; vertical-alignment: center; }
                        }
                        Rectangle { }
                        // zoom control
                        Text { text: "ZOOM"; color: Theme.text3; font-size: 10px; letter-spacing: 1px; vertical-alignment: center; }
                        Slider { width: 150px; minimum: 0.5; maximum: 2.5; value: root.zoom; changed(v) => { root.zoom = v; } }
                        Text { text: Math.round(root.zoom * 100) + "%"; color: Theme.text2; font-family: Theme.mono-font; font-size: 11px; vertical-alignment: center; }
                        Rectangle { width: 12px; }
                        Text { text: DeviceCaps.main-res; color: Theme.text3; font-family: Theme.mono-font; font-size: 11px; vertical-alignment: center; }
                    }
                    // live mirror — fit to stage, then * zoom; centred (no Flickable, so
                    // node drag/resize gestures aren't intercepted by flick-panning).
                    stage := Rectangle {
                        vertical-stretch: 1;
                        clip: true;
                        property <float> fit: min(1.0, min((self.width - 24px) / (DeviceCaps.main-w * 1px), (self.height - 24px) / (DeviceCaps.main-h * 1px))) * root.zoom;
                        canvas := Rectangle {
                            width: DeviceCaps.main-w * 1px * stage.fit + 12px;
                            height: DeviceCaps.main-h * 1px * stage.fit + 12px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            drop-shadow-blur: 18px;
                            drop-shadow-color: #000000;
                            background: #000000;
                            border-radius: 16px;
                            // The real pith-ui engine renders this image (same fonts +
                            // draw code as the device), so it is pixel-identical to the panel.
                            Image {
                                x: 6px;
                                y: 6px;
                                width: parent.width - 12px;
                                height: parent.height - 12px;
                                source: RaceLayout.preview-image;
                                image-rendering: pixelated;
                            }
                            // interactive freeform overlays (select / drag / resize)
                            for n in RaceLayout.nodes: NodeOverlay {
                                node: n;
                                scale: stage.fit;
                                ox: 6px;
                                oy: 6px;
                            }
                            // snap guide lines (active while dragging)
                            if RaceLayout.snap-vx >= 0: Rectangle {
                                x: 6px + RaceLayout.snap-vx * stage.fit * 1px;
                                y: 6px;
                                width: 1px;
                                height: parent.height - 12px;
                                background: Theme.accent;
                            }
                            if RaceLayout.snap-hy >= 0: Rectangle {
                                x: 6px;
                                y: 6px + RaceLayout.snap-hy * stage.fit * 1px;
                                width: parent.width - 12px;
                                height: 1px;
                                background: Theme.accent;
                            }
                        }
                    }
                    Text { text: "Drag a widget to move · drag the corner to resize · click to select · add widgets on the right."; color: Theme.text3; font-size: 12px; horizontal-alignment: center; }
                }
            }
            // freeform editor panel
            VerticalLayout {
                width: 320px;
                spacing: 12px;
                // display selector (the DDU drives two panels)
                if RaceLayout.display-count > 1: HorizontalLayout {
                    spacing: 8px;
                    for d in [0, 1]: Rectangle {
                        height: 30px;
                        horizontal-stretch: 1;
                        background: RaceLayout.edit-display == d ? Theme.accent-dim : Theme.panel;
                        border-radius: 7px;
                        border-width: 1px;
                        border-color: RaceLayout.edit-display == d ? Theme.accent : Theme.line;
                        Text {
                            text: "Display " + (d + 1);
                            color: RaceLayout.edit-display == d ? Theme.accent : Theme.text2;
                            font-family: Theme.display-font;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        TouchArea { clicked => { RaceLayout.switch-display(d); } }
                    }
                }
                // add-widget palette
                Card {
                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;
                        HorizontalLayout {
                            Text { text: "ADD WIDGET"; color: Theme.text2; font-family: Theme.display-font; font-size: 12px; font-weight: 600; letter-spacing: 1px; vertical-alignment: center; }
                            Rectangle { }
                            Text { text: RaceLayout.nodes.length + " on this display"; color: Theme.text3; font-size: 11px; vertical-alignment: center; }
                        }
                        Flickable {
                            height: 116px;
                            vertical-stretch: 0;
                            viewport-height: cat-flow.preferred-height;
                            cat-flow := VerticalLayout {
                                spacing: 5px;
                                alignment: start;
                                for md in RaceLayout.catalog: Rectangle {
                                    height: 25px;
                                    border-radius: 5px;
                                    background: addta.has-hover ? Theme.elev : Theme.panel2;
                                    HorizontalLayout {
                                        padding-left: 10px;
                                        padding-right: 10px;
                                        Text { text: md.name; color: Theme.text2; font-size: 12px; vertical-alignment: center; horizontal-stretch: 1; }
                                        Text { text: "+"; color: Theme.accent; font-size: 15px; vertical-alignment: center; }
                                    }
                                    addta := TouchArea { clicked => { RaceLayout.node-add(md.type); } }
                                }
                            }
                        }
                    }
                }
                // selected-widget editor (or a hint)
                if RaceLayout.sel-id != "": Flickable {
                    vertical-stretch: 1;
                    viewport-height: edit-col.preferred-height;
                    edit-col := VerticalLayout { EditPanel { } }
                }
                if RaceLayout.sel-id == "": Rectangle {
                    vertical-stretch: 1;
                    Text {
                        text: "Select a widget on the canvas to edit it,\nor add one above.";
                        color: Theme.text3;
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        wrap: word-wrap;
                    }
                }
            }
        }
    }
}
