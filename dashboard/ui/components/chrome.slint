// Title bar + left sidebar nav (HANDOFF.md §1 app shell).
import { Theme } from "../theme.slint";
import { AppState, Page, Firmware, Hb, Pedals } from "../models.slint";
import { Dot } from "../widgets.slint";

export component TitleBar inherits Rectangle {
    height: 46px;
    background: Theme.titlebar;
    HorizontalLayout {
        padding-left: 16px;
        padding-right: 12px;
        spacing: 10px;
        // logo
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 23px;
                height: 23px;
                border-radius: 6px;
                background: Theme.accent;
                Text {
                    text: "P";
                    color: Theme.accent-text;
                    font-family: Theme.display-font;
                    font-weight: 700;
                    font-size: 15px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                spacing: 6px;
                Text {
                    text: "PITH";
                    color: Theme.text;
                    font-family: Theme.display-font;
                    font-weight: 700;
                    font-size: 16px;
                    letter-spacing: 2px;
                    vertical-alignment: center;
                }
                Text {
                    text: "DASHBOARD";
                    color: Theme.text3;
                    font-family: Theme.display-font;
                    font-weight: 600;
                    font-size: 16px;
                    letter-spacing: 2px;
                    vertical-alignment: center;
                }
            }
        }
        Rectangle { }  // spacer
        // No window controls or per-device status up here: the OS titlebar
        // already provides minimize/maximize/close, and device status/firmware
        // is per-device information (the sidebar gear cards + Firmware page).
    }
}

component NavRow inherits Rectangle {
    in property <string> glyph;
    in property <string> label;
    in property <bool> active: false;
    in property <bool> dot: false;
    callback clicked;
    height: 40px;
    background: active ? Theme.accent-dim : (ta.has-hover ? Theme.panel : transparent);
    border-radius: 8px;
    // inset accent left bar when active
    Rectangle {
        x: 0;
        width: 2px;
        height: active ? 22px : 0px;
        y: parent.height / 2 - self.height / 2;
        background: Theme.accent;
        border-radius: 1px;
        animate height { duration: 120ms; }
    }
    HorizontalLayout {
        padding-left: 14px;
        padding-right: 12px;
        spacing: 11px;
        VerticalLayout {
            alignment: center;
            Text {
                text: root.glyph;
                color: active ? Theme.accent : Theme.text2;
                font-size: 14px;
                width: 16px;
                horizontal-alignment: center;
            }
        }
        VerticalLayout {
            alignment: center;
            Text {
                text: root.label;
                color: active ? Theme.text : Theme.text2;
                font-family: Theme.body-font;
                font-size: 14px;
                font-weight: active ? 600 : 500;
                vertical-alignment: center;
            }
        }
        Rectangle { }
        if root.dot: VerticalLayout {
            alignment: center;
            Rectangle { width: 6px; height: 6px; border-radius: 3px; background: Theme.accent; }
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

// One connected-gear status card (bottom of the sidebar, one per device).
component GearCard inherits Rectangle {
    in property <string> name;
    in property <bool> connected: false;
    in property <string> detail: "";
    in property <string> serial: "";
    in property <string> fw: "";
    in property <bool> active: false;
    callback clicked;
    height: 86px;
    background: card-ta.has-hover ? Theme.elev : Theme.panel;
    border-radius: 10px;
    border-width: 1px;
    border-color: active ? Theme.accent : Theme.line;
    card-ta := TouchArea { clicked => { root.clicked(); } }
    VerticalLayout {
        padding: 12px;
        spacing: 7px;
        HorizontalLayout {
            spacing: 7px;
            VerticalLayout { alignment: center; Dot { tint: root.connected ? Theme.green : Theme.text3; } }
            Text {
                text: root.name;
                color: Theme.text;
                font-family: Theme.display-font;
                font-size: 14px;
                font-weight: 600;
                vertical-alignment: center;
            }
        }
        Text {
            text: root.detail;
            color: Theme.text3;
            font-size: 11px;
        }
        // device serial number + firmware version
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: root.serial != "" ? root.serial : "—";
                color: Theme.text3;
                font-family: Theme.mono-font;
                font-size: 10px;
                overflow: elide;
                horizontal-stretch: 1;
            }
            Text {
                text: root.fw;
                color: Theme.text3;
                font-family: Theme.mono-font;
                font-size: 10px;
                horizontal-alignment: right;
            }
        }
    }
}

export component Sidebar inherits Rectangle {
    width: 212px;
    background: Theme.sidebar;
    VerticalLayout {
        padding: 14px;
        spacing: 4px;
        Text {
            text: "CONFIGURE";
            color: Theme.text3;
            font-family: Theme.display-font;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 1.6px;
        }
        Rectangle { height: 6px; }
        NavRow { glyph: "▦"; label: "Overview"; active: AppState.page == Page.overview; clicked => { AppState.page = Page.overview; } }
        NavRow { glyph: "▤"; label: "Screens"; active: AppState.page == Page.race; clicked => { AppState.page = Page.race; } }
        NavRow { glyph: "▰"; label: "Shift Lights"; active: AppState.page == Page.shift; clicked => { AppState.page = Page.shift; } }
        NavRow { glyph: "◈"; label: "Car Library"; active: AppState.page == Page.cars; clicked => { AppState.page = Page.cars; } }
        NavRow { glyph: "⇅"; label: "Telemetry UDP"; active: AppState.page == Page.udp; clicked => { AppState.page = Page.udp; } }
        NavRow { glyph: "⬡"; label: "Firmware"; active: AppState.page == Page.firmware; dot: Firmware.update-available || Hb.update-available || Pedals.update-available; clicked => { AppState.page = Page.firmware; } }
        NavRow { glyph: "≋"; label: "Wireless"; active: AppState.page == Page.wireless; clicked => { AppState.page = Page.wireless; } }
        Rectangle { }  // spacer
        // Connected-gear card list: one status card per Pith device, pinned to
        // the bottom of the sidebar. Click a card to open that device's page.
        GearCard {
            name: AppState.device-name;
            connected: AppState.connected;
            detail: AppState.conn-detail;
            serial: AppState.serial;
            fw: AppState.connected ? AppState.fw-version : "";
            active: AppState.page == Page.device;
            clicked => { AppState.page = Page.device; }
        }
        GearCard {
            name: "Pith Handbrake";
            connected: Hb.connected;
            detail: Hb.connected ? Hb.board : (Hb.device-found ? "Detected — connecting…" : "Disconnected");
            serial: Hb.serial;
            fw: Hb.fw-version != "" ? "v" + Hb.fw-version : "";
            active: AppState.page == Page.handbrake;
            clicked => { AppState.page = Page.handbrake; }
        }
        GearCard {
            name: "Pith Pedal";
            connected: Pedals.connected;
            detail: Pedals.connected ? Pedals.board : (Pedals.device-found ? "Detected — connecting…" : "Disconnected");
            serial: Pedals.serial;
            fw: Pedals.fw-version != "" ? "v" + Pedals.fw-version : "";
            active: AppState.page == Page.pedals;
            clicked => { AppState.page = Page.pedals; }
        }
    }
    // hairline divider on the right
    Rectangle { x: parent.width - 1px; width: 1px; background: Theme.line; }
}
