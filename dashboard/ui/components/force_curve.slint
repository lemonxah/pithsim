// Interactive force-vs-travel curve editor — the dashboard's replacement for
// the SimHub plugin's `CurveTab_PedalForceTravel` editor. A cubic-spline
// polyline (computed in Rust, pith-pedals-core::curve) is drawn as an SVG
// Path in a 0..1 viewbox; draggable handles sit on the control points;
// right-click adds/removes a point. Preset buttons and range sliders frame
// the curve exactly like the reference (Linear/S-Curve/Exponent/Logarithm,
// Max force / Preload, travel window).
import { Theme } from "../theme.slint";
import { SectionLabel, Mono, AppSlider } from "../widgets.slint";
import { Pedals } from "../models.slint";
import { LineEdit } from "std-widgets.slint";

component PresetButton inherits Rectangle {
    in property <string> label;
    callback clicked();
    width: txt.preferred-width + 20px;
    height: 24px;
    border-radius: 4px;
    background: ta.has-hover ? Theme.elev : Theme.panel2;
    border-width: 1px;
    border-color: Theme.line2;
    txt := Text {
        text: root.label;
        color: Theme.text2;
        font-size: 11px;
        font-family: Theme.body-font;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    ta := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component ForceCurveEditor inherits VerticalLayout {
    spacing: 12px;

    // True while the pointer is over the plot OR actively dragging a control
    // point. The page's Flickable binds `interactive: !plot-active` to this so
    // a left-drag on the curve moves the point instead of being stolen as a
    // flick-scroll gesture (the Flickable is an ancestor of the plot). `pressed`
    // keeps it latched even if a fast drag leaves the plot bounds mid-gesture.
    out property <bool> plot-active: plot-ta.has-hover || plot-ta.pressed;

    HorizontalLayout {
        spacing: 8px;
        SectionLabel {
            text: "FORCE CURVE";
            horizontal-stretch: 1;
        }
        PresetButton {
            label: "Linear";
            clicked => {
                Pedals.curve-preset("linear");
            }
        }
        PresetButton {
            label: "S-Curve";
            clicked => {
                Pedals.curve-preset("s-curve");
            }
        }
        PresetButton {
            label: "Exponent";
            clicked => {
                Pedals.curve-preset("exponent");
            }
        }
        PresetButton {
            label: "Logarithm";
            clicked => {
                Pedals.curve-preset("logarithm");
            }
        }
    }

    HorizontalLayout {
        spacing: 12px;

        // ---- plot ----
        // Fixed 2.5:1 aspect (height derived from width) so the spline Path's
        // 2.5×1 viewbox fits exactly at any width — no aspect distortion.
        plot := Rectangle {
            horizontal-stretch: 1;
            height: self.width / 2.5;
            background: #171a22;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.line2;
            clip: true;

            // axis labels
            Text {
                text: "FORCE";
                color: Theme.text3;
                font-size: 10px;
                x: 6px;
                y: 6px;
            }
            Text {
                text: "TRAVEL";
                color: Theme.text3;
                font-size: 10px;
                x: parent.width - self.width - 8px;
                y: parent.height - 16px;
            }

            // grid (quarters)
            for i in [1, 2, 3]: Rectangle {
                width: 1px;
                height: parent.height;
                x: parent.width / 4 * i;
                background: Theme.line;
            }
            for i in [1, 2, 3]: Rectangle {
                height: 1px;
                width: parent.width;
                y: parent.height / 4 * i;
                background: Theme.line;
            }

            // The spline curve. Commands are emitted (in Rust) in a 2.5×1
            // coordinate space matching the plot's fixed aspect, so this
            // aspect-preserving Path fills the plot exactly.
            Path {
                width: 100%;
                height: 100%;
                viewbox-x: 0;
                viewbox-y: 0;
                viewbox-width: 2.5;
                viewbox-height: 1;
                commands: Pedals.spline-commands;
                stroke: Theme.accent;
                stroke-width: 2px;
            }

            // control-point handles (visual; the overlay TouchArea drives them)
            for pt in Pedals.curve-points: Rectangle {
                width: 11px;
                height: 11px;
                border-radius: 2px;
                background: Theme.accent;
                border-width: 1px;
                border-color: Theme.bg;
                x: pt.x * (plot.width - self.width);
                y: (1 - pt.y) * (plot.height - self.height);
            }

            // one overlay TouchArea in plot coordinates handles drag + rclick
            plot-ta := TouchArea {
                property <int> dragging: -1;
                pointer-event(ev) => {
                    if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
                        self.dragging = Pedals.curve-nearest(self.mouse-x / plot.width, 1 - self.mouse-y / plot.height);
                    } else if (ev.kind == PointerEventKind.up) {
                        self.dragging = -1;
                    } else if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.right) {
                        Pedals.curve-right-click(
                            Math.clamp(self.mouse-x / plot.width, 0, 1),
                            Math.clamp(1 - self.mouse-y / plot.height, 0, 1));
                    }
                }
                moved => {
                    if (self.dragging >= 0) {
                        Pedals.curve-point-moved(
                            self.dragging,
                            Math.clamp(self.mouse-x / plot.width, 0, 1),
                            Math.clamp(1 - self.mouse-y / plot.height, 0, 1));
                    }
                }
            }
        }

        // ---- vertical force range readout ----
        VerticalLayout {
            width: 68px;
            alignment: space-between;
            VerticalLayout {
                spacing: 1px;
                Text { text: "Max force"; color: Theme.text3; font-size: 10px; }
                Mono { text: "\{Pedals.max-force-kg} kg"; font-size: 13px; }
            }
            VerticalLayout {
                spacing: 1px;
                Text { text: "Preload"; color: Theme.text3; font-size: 10px; }
                Mono { text: "\{Pedals.preload-kg} kg"; font-size: 13px; }
            }
        }
    }

    Text {
        text: "Drag the points to shape the curve. Right-click to add a point, or right-click a point to remove it.";
        color: Theme.text3;
        font-size: 11px;
        wrap: word-wrap;
    }

    // ---- range sliders (frame the curve, like the reference's dual sliders) ----
    Rangeslider := VerticalLayout {
        spacing: 8px;
        HorizontalLayout {
            spacing: 10px;
            VerticalLayout {
                alignment: center;
                horizontal-stretch: 1;
                spacing: 1px;
                Text { text: "Max force (this pedal)"; color: Theme.text; font-size: 12px; }
                Text {
                    text: "Force at 100% output. Set per pedal — keep it under your load cell's rating (e.g. 45 kg on a 50 kg cell for the brake).";
                    color: Theme.text3; font-size: 10px; wrap: word-wrap;
                }
            }
            maxf-edit := LineEdit {
                width: 58px;
                horizontal-alignment: right;
                text: "\{Pedals.max-force-kg}";
                input-type: number;
                edited(t) => {
                    if (t.is-float() && t.to-float() >= 1 && t.to-float() <= 200) {
                        Pedals.max-force-kg = Math.round(t.to-float());
                        Pedals.curve-range-changed();
                    }
                }
            }
            Mono { text: "kg"; font-size: 12px; vertical-alignment: center; }
        }
        AppSlider {
            minimum: 1;
            maximum: 200;
            value: Pedals.max-force-kg;
            changed(v) => {
                Pedals.max-force-kg = Math.round(v);
                maxf-edit.text = "\{Math.round(v)}";
                Pedals.curve-range-changed();
            }
        }
        HorizontalLayout {
            spacing: 10px;
            Text { text: "Preload"; color: Theme.text; font-size: 12px; vertical-alignment: center; horizontal-stretch: 1; }
            preload-edit := LineEdit {
                width: 58px;
                horizontal-alignment: right;
                text: "\{Pedals.preload-kg}";
                input-type: number;
                edited(t) => {
                    if (t.is-float() && t.to-float() >= 0 && t.to-float() <= 100) {
                        Pedals.preload-kg = Math.round(t.to-float());
                        Pedals.curve-range-changed();
                    }
                }
            }
            Mono { text: "kg"; font-size: 12px; vertical-alignment: center; }
        }
        AppSlider {
            minimum: 0;
            maximum: 100;
            value: Pedals.preload-kg;
            changed(v) => {
                Pedals.preload-kg = Math.round(v);
                preload-edit.text = "\{Math.round(v)}";
                Pedals.curve-range-changed();
            }
        }
        HorizontalLayout {
            spacing: 10px;
            Text { text: "Travel start"; color: Theme.text; font-size: 12px; vertical-alignment: center; horizontal-stretch: 1; }
            Mono { text: "\{Pedals.pedal-start-pct}%"; font-size: 12px; vertical-alignment: center; }
        }
        AppSlider {
            minimum: 0;
            maximum: 95;
            value: Pedals.pedal-start-pct;
            changed(v) => {
                Pedals.pedal-start-pct = Math.round(v);
                Pedals.curve-range-changed();
            }
        }
        HorizontalLayout {
            spacing: 10px;
            Text { text: "Travel end"; color: Theme.text; font-size: 12px; vertical-alignment: center; horizontal-stretch: 1; }
            Mono { text: "\{Pedals.pedal-end-pct}%"; font-size: 12px; vertical-alignment: center; }
        }
        AppSlider {
            minimum: 5;
            maximum: 100;
            value: Pedals.pedal-end-pct;
            changed(v) => {
                Pedals.pedal-end-pct = Math.round(v);
                Pedals.curve-range-changed();
            }
        }
    }
}
